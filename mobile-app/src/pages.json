{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    { "path": "pages/index/index", "style": { "navigationStyle": "custom" } },
    { "path": "pages/theater/index", "style": { "navigationStyle": "custom" } },
    { "path": "pages/player/index", "style": { "navigationStyle": "custom" } },
    { "path": "pages/drama-detail/index", "style": { "navigationBarTitleText": "剧目", "navigationBarBackgroundColor": "#0a0a0f" } },
    { "path": "pages/mine/index", "style": { "navigationStyle": "custom" } },
    { "path": "pages/login/index", "style": { "navigationBarTitleText": "登录", "navigationBarBackgroundColor": "#0a0a0f" } },
    { "path": "pages/search/index", "style": { "navigationStyle": "custom" } },
    { "path": "pages/watch-history/index", "style": { "navigationBarTitleText": "观看记录", "navigationBarBackgroundColor": "#0a0a0f" } },
    { "path": "pages/favorites/index", "style": { "navigationBarTitleText": "我的收藏", "navigationBarBackgroundColor": "#0a0a0f" } },
    { "path": "pages/privacy/index", "style": { "navigationBarTitleText": "隐私政策", "navigationBarBackgroundColor": "#0a0a0f" } },
    { "path": "pages/privacy/agreement", "style": { "navigationBarTitleText": "用户协议", "navigationBarBackgroundColor": "#0a0a0f" } },
    { "path": "pages/privacy/about", "style": { "navigationBarTitleText": "关于我们", "navigationBarBackgroundColor": "#0a0a0f" } }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarBackgroundColor": "#0a0a0f",
    "backgroundColor": "#0a0a0f"
  }
}
