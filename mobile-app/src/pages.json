{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    { "path": "pages/index/index", "style": { "navigationStyle": "custom" } },
    { "path": "pages/theater/index", "style": { "navigationStyle": "custom" } },
    { "path": "pages/player/index", "style": { "navigationBarTitleText": "沉浸播放", "navigationBarBackgroundColor": "#000000" } },
    { "path": "pages/drama-detail/index", "style": { "navigationBarTitleText": "剧目", "navigationBarBackgroundColor": "#0a0a0f" } },
    { "path": "pages/mine/index", "style": { "navigationStyle": "custom" } },
    { "path": "pages/login/index", "style": { "navigationBarTitleText": "登录", "navigationBarBackgroundColor": "#0a0a0f" } },
    { "path": "pages/watch-history/index", "style": { "navigationBarTitleText": "观看记录", "navigationBarBackgroundColor": "#0a0a0f" } }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarBackgroundColor": "#0a0a0f",
    "backgroundColor": "#0a0a0f"
  }
}
