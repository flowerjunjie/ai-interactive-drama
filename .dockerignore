# .dockerignore
# 减少 Docker 构建上下文，避免无用文件污染镜像

# ── 版本控制 ───────────────────────────────────────
.git/
.gitattributes
.gitignore

# ── Python 缓存 / 虚拟环境 ──────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.python-version
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
*.egg-info/

# ── Node 生态 ──────────────────────────────────────
node_modules/
.pnpm-store/
.pnp.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── 构建产物 ──────────────────────────────────────
dist/
build/
out/
target/
*.tsbuildinfo
.next/
.nuxt/
.cache/
.parcel-cache/
.vite/

# ── 文档 / 笔记（不进镜像）────────────────────────
*.md
!README.md
docs/
.worklog/
CHANGELOG.md
CHANGES.md
ROADMAP.md
SECURITY.md
CONTRIBUTING.md
CODE_OF_CONDUCT.md
LICENSE
.claude/
.agents/
.claude-flow/
.codegraph/
.codereview/
.infrastructure/
.performance/
.security/

# ── IDE / 编辑器 ──────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── 测试 / fixtures ───────────────────────────────
tests/fixtures/
*.test.js
*.spec.js
coverage/
.nyc_output/

# ── 日志 / 临时文件 ───────────────────────────────
*.log
logs/
*.tmp
*.bak
*.swp

# ── 大型资源（不进镜像，靠 volume 挂载）───────────
backups/
download-page/
*.apk
*.ipa
*.dmg
*.zip
*.tar.gz
*.gz
*.rar
*.7z

# ── Secrets（永远不进镜像！）───────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/

# ── 工作流文件不镜像（运行时用不到）────────────────
.github/
.gitlab-ci.yml
.circleci/

# ── Pre-commit ────────────────────────────────────
.pre-commit-config.yaml
.pre-commit-hooks.yaml

# ── Docker 自身 ────────────────────────────────────
Dockerfile*
docker-compose*.yml
.dockerignore