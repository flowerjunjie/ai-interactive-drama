# 环境变量示例（复制为 .env.dev / .env.prod 并按需填写）
# --- 火山引擎 TOS（后台上传 /api/admin/drama/upload/sign）---
VOLCENGINE_TOS_ACCESS_KEY=
VOLCENGINE_TOS_SECRET_KEY=
VOLCENGINE_TOS_REGION=cn-beijing
VOLCENGINE_TOS_ENDPOINT=tos-cn-beijing.volces.com
VOLCENGINE_TOS_BUCKET=
VOLCENGINE_TOS_PRESIGN_EXPIRES=3600
VOLCENGINE_TOS_CDN_DOMAIN=

# --- 传输加密：移动端直连 /api 时建议排除（追加逗号分隔路径）---
# TRANSPORT_CRYPTO_EXCLUDE_PATHS=/openapi.json,/docs,...,/api
